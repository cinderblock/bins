{
  "name": "bins",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Offline-first PWA inventory tracker for group storage bins — scan a QR sticker, see what's inside, snap a photo, move on.",
  "scripts": {
    "dev": "concurrently -k -n web,api \"bun --bun react-router dev\" \"bun --watch api/dev.ts\"",
    "dev:web": "bun --bun react-router dev",
    "dev:api": "bun --watch api/dev.ts",
    "build": "react-router build",
    "start": "bun server.ts",
    "test": "bun test",
    "typecheck": "react-router typegen && tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@mantine/core": "^8.0.0",
    "@mantine/hooks": "^8.0.0",
    "@mantine/notifications": "^8.0.0",
    "@react-router/node": "^7.13.0",
    "@tabler/icons-react": "^3.31.0",
    "barcode-detector": "^3.0.0",
    "dexie": "^4.0.11",
    "dexie-react-hooks": "^1.1.7",
    "drizzle-orm": "^0.45.2",
    "minisearch": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router": "^7.13.0",
    "uqr": "^0.1.2",
    "uuid": "^11.1.0",
    "zod": "^3.24.0",
    "isbot": "^5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@react-router/dev": "^7.13.0",
    "@types/bun": "latest",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.1.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.49",
    "postcss-preset-mantine": "^1.17.0",
    "postcss-simple-vars": "^7.0.1",
    "sharp": "^0.35.3",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-tsconfig-paths": "^5.1.0"
  },
  "trustedDependencies": ["@biomejs/biome"]
}
