# --- Web (dev) ---
# Vite dev server port; the dev API attaches at API_PORT and Vite proxies /api.
PORT=3000
API_PORT=3001
# Public origin the app is served from. Locally: http://localhost:3000.
# Production: your public origin, e.g. https://bins.example.org. QR codes
# carry this origin (they're generated from the page's own location).
PUBLIC_BASE_URL=http://localhost:3000

# --- Server ---
# Production only: unix socket the Bun server binds (Caddy proxies to it).
#SOCKET_PATH=/run/bins/bins.sock
# SQLite database file. Created + migrated automatically on boot.
DATABASE_PATH=./data/bins.db
# Directory for content-addressed photo blobs.
PHOTOS_PATH=./data/photos

# --- Bootstrap (optional) ---
# If set and no group exists yet, a first group is created on boot.
# Equivalent to: bun scripts/create-group.ts "<name>" "<access code>"
#BOOTSTRAP_GROUP_NAME=My Group
#BOOTSTRAP_ACCESS_CODE=change-me
